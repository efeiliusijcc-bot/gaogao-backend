# Tavily Search API
TAVILY_API_KEY=

# OpenClaw 配置
OPENCLAW_BASE_URL=http://localhost:1888/v1
OPENCLAW_API_KEY=
OPENCLAW_MODEL=openclaw/report-agent

# 远程 SSH 配置（本地开发时可留空）
OPENCLAW_REMOTE_HOST=
OPENCLAW_REMOTE_USER=root
OPENCLAW_REMOTE_SSH_KEY=~/.ssh/id_ed25519
OPENCLAW_REMOTE_REPORT_DIR=/usr/docker/openclaw/workspace/report-agent/reports

# Optional: PostgreSQL pgvector semantic source recall.
# Example: postgres://user:password@host:5432/news
PGVECTOR_DATABASE_URL=
PGVECTOR_NEWS_TABLE=news
PGVECTOR_INDEX_TABLE=news_vector_chunks
PGVECTOR_EMBEDDING_MODEL=text-embedding-3-small

# Optional: local Qwen3 embedding service, OpenAI-compatible /v1/embeddings.
# Keep this in a separate table because Qwen3-Embedding-0.6B uses 1024-dimensional vectors.
# PGVECTOR_NEWS_TABLE=vector_materials_qwen3
# PGVECTOR_EMBEDDING_MODEL=Qwen3-Embedding-0.6B-Q8
# PGVECTOR_EMBEDDING_DIMENSIONS=1024
# PGVECTOR_EMBEDDING_INPUT_CHARS=2000
# PGVECTOR_EMBEDDING_BASE_URL=http://127.0.0.1:8000/v1
# If your local embedding server rejects the "dimensions" parameter, set:
# PGVECTOR_OMIT_EMBEDDING_DIMENSIONS=1

# 部署配置（deploy.sh 使用）
REMOTE_HOST=
REMOTE_USER=root
SSH_KEY=~/.ssh/id_ed25519
