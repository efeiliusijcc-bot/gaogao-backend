# Tavily Search API
TAVILY_API_KEY=

# OpenClaw 配置
OPENCLAW_BASE_URL=http://localhost:1888/v1
OPENCLAW_API_KEY=
OPENCLAW_MODEL=openclaw/report-agent

# 远程 SSH 配置（本地开发时可留空）
OPENCLAW_REMOTE_HOST=
OPENCLAW_REMOTE_USER=root
OPENCLAW_REMOTE_SSH_KEY=~/.ssh/id_ed25519
OPENCLAW_REMOTE_REPORT_DIR=/usr/docker/openclaw/workspace/report-agent/reports

# 部署配置（deploy.sh 使用）
REMOTE_HOST=
REMOTE_USER=root
SSH_KEY=~/.ssh/id_ed25519
